# Copy to .env and fill in values. The .env file is git-ignored.
# Real OS environment variables take precedence over values set here.

# --- LLM agent (required to run the assistant) ------------------------------
# The assistant uses an LLM to orchestrate the MCP tools, so it needs a key.
# The MCP server, the tests, and MCP hosts (Claude/VS Code) work without one.
OPENAI_API_KEY=

# LLM backend to use (default: openai). See "Switching the model" in README.
# LLM_PROVIDER=openai

# Model to use for the assistant (default: gpt-5.4-nano).
OPENAI_MODEL=gpt-5.4-nano

# Optional: point at any OpenAI-compatible endpoint instead of OpenAI,
# e.g. a local Ollama server (http://localhost:11434/v1) or LM Studio.
# If unset, defaults to OpenAI's EU regional endpoint.
# OPENAI_BASE_URL=

# --- Server / data ----------------------------------------------------------
# Logging level for the MCP server (default: INFO).
# Valid values: CRITICAL, ERROR, WARNING, INFO, DEBUG.
LOG_LEVEL=INFO

# Optional override for where OpenFlights datasets are cached.
# OPENFLIGHTS_DATA_DIR=./data
